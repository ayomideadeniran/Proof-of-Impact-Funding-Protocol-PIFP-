ORACLE_PORT=3001
ORACLE_USE_SNCAST=true
ORACLE_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_9/YOUR_ALCHEMY_KEY
ORACLE_RPC_URL_FALLBACK=https://api.cartridge.gg/x/starknet/sepolia
ORACLE_SNCAST_BIN=sncast
ORACLE_SNCAST_ACCOUNT=pifp_deployer
ORACLE_ACCOUNTS_FILE=/path/to/starknet_accounts.json
# Optional for Render: full contents of your Starknet accounts JSON file.
ORACLE_SNCAST_ACCOUNTS_JSON={"alpha-sepolia":{"pifp_deployer":{"address":"0x...","class_hash":"0x...","deployed":true,"legacy":false,"private_key":"0x...","public_key":"0x...","salt":"0x...","type":"open_zeppelin"}}}
ORACLE_CALLER_ADDRESS=0xYOUR_ORACLE_ACCOUNT_ADDRESS
ORACLE_PIFP_CONTRACT_ADDRESS=0x077717258ff67e2256452158eb35aa13fa15d6d8a4430049581e4223959a07c1
ORACLE_WALLET_EMAIL_FILE=wallet_emails.json

# OTP / Email delivery
ORACLE_OTP_TTL_SECONDS=300
ORACLE_VERIFIED_OTP_WINDOW_SECONDS=180
ORACLE_ACTION_TOKEN_TTL_SECONDS=300
ORACLE_EXPOSE_OTP=false
ORACLE_SKIP_SMTP_WHEN_DEV=true
ORACLE_ENABLE_ONCHAIN_EMAIL_HASH_SYNC=false
ORACLE_OTP_PROVIDER=smtp

# Resend provider (used when ORACLE_OTP_PROVIDER=resend)
ORACLE_RESEND_API_KEY=re_your_api_key
ORACLE_RESEND_FROM_EMAIL=noreply@your-domain.com
ORACLE_RESEND_API_URL=https://api.resend.com/emails

ORACLE_SMTP_HOST=smtp.gmail.com
ORACLE_SMTP_PORT=587
ORACLE_SMTP_USERNAME=your_email@example.com
ORACLE_SMTP_PASSWORD=your_app_password_or_smtp_password
ORACLE_FROM_EMAIL=your_email@example.com
